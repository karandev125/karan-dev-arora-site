<button
  class="theme-toggle"
  type="button"
  data-theme-toggle
  aria-label="Switch to dark theme"
  aria-pressed="false"
>
  <svg class="theme-toggle__sun" aria-hidden="true" viewBox="0 0 24 24" fill="none">
    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.75" />
    <path
      d="M12 2.75v2.5M12 18.75v2.5M4.75 4.75l1.75 1.75M17.5 17.5l1.75 1.75M2.75 12h2.5M18.75 12h2.5M4.75 19.25l1.75-1.75M17.5 6.5l1.75-1.75"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-width="1.75"
    />
  </svg>
  <svg class="theme-toggle__moon" aria-hidden="true" viewBox="0 0 24 24" fill="none">
    <path
      d="M20.25 14.55A8.35 8.35 0 0 1 9.45 3.75 8.8 8.8 0 1 0 20.25 14.55Z"
      stroke="currentColor"
      stroke-linejoin="round"
      stroke-width="1.75"
    />
  </svg>
</button>
