---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { getCollection } from "astro:content";
import { formatDate } from "../../lib/date";

const notes = (await getCollection("notes"))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.tendedAt.getTime() - a.data.tendedAt.getTime());
---

<BaseLayout title="Notes" wide>
  <section class="page-section" aria-labelledby="page-title">
    <h1 id="page-title" class="page-title">
      Notes{notes.length > 0 && <span class="mono"> ({notes.length})</span>}
    </h1>
    <p class="page-intro">Working thoughts. Less polished than essays, more permanent than tweets.</p>

    {
      notes.length === 0 ? (
        <p class="placeholder-list">Nothing here yet.</p>
      ) : (
        <div class="note-list" aria-label="Notes">
          {notes.map((note) => (
            <a class="note-row" href={`/notes/${note.slug}`}>
              <span class="note-row__title">{note.data.title}</span>
              <span class="note-row__meta">
                tended {formatDate(note.data.tendedAt)}
                <span class:list={["stage-label", `stage-label--${note.data.stage}`]}>{note.data.stage}</span>
              </span>
            </a>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
