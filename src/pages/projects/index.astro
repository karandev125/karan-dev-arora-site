---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { getCollection, type CollectionEntry } from "astro:content";

type Project = CollectionEntry<"projects">;
type ProjectCategory = Project["data"]["category"];

const categories: { id: ProjectCategory; label: string }[] = [
  { id: "live", label: "Live" },
  { id: "past", label: "Past" },
  { id: "experiments", label: "Experiments" },
  { id: "failures", label: "Failures" },
];

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title));

const groupedProjects = categories
  .map((category) => ({
    ...category,
    projects: projects.filter((project) => project.data.category === category.id),
  }))
  .filter((group) => group.projects.length > 0);
---

<BaseLayout title="Projects">
  <section class="page-section" aria-labelledby="page-title">
    <h1 id="page-title" class="page-title">Projects</h1>
    <p class="page-intro">Things I've made. Some live, some learning.</p>

    {
      projects.length === 0 ? (
        <p class="placeholder-list">Nothing here yet.</p>
      ) : (
        <div class="stacked-sections">
          {groupedProjects.map((group) => (
            <section aria-labelledby={`projects-${group.id}`}>
              <h2 id={`projects-${group.id}`} class="section-label">{group.label}</h2>
              <div class="project-list">
                {group.projects.map((project) => (
                  <article class="project-entry">
                    <div class="project-entry__heading">
                      <h3>{project.data.title}</h3>
                      <span>{project.data.year}</span>
                    </div>
                    <p>{project.data.description}</p>
                    <div class="project-entry__links">
                      {project.data.links.map((link) => (
                        <a href={link.href}>{link.label} &nearr;</a>
                      ))}
                      <a href={`/projects/${project.slug}`}>details &rarr;</a>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
