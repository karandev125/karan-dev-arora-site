---
import BaseLayout from "../../../layouts/BaseLayout.astro";

import { getCollection, type CollectionEntry } from "astro:content";
import { formatDate } from "../../../lib/date";

type Bookmark = CollectionEntry<"bookmarks">;

interface Props {
  tag: string;
  bookmarks: Bookmark[];
}

export async function getStaticPaths() {
  const bookmarks = (await getCollection("bookmarks"))
    .filter((bookmark) => !bookmark.data.draft)
    .sort((a, b) => b.data.savedAt.getTime() - a.data.savedAt.getTime());
  const tags = [...new Set(bookmarks.flatMap((bookmark) => bookmark.data.tags))].sort();

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      bookmarks: bookmarks.filter((bookmark) => bookmark.data.tags.includes(tag)),
    },
  }));
}

const { tag, bookmarks } = Astro.props;

function sourceLabel(bookmark: Bookmark): string {
  return [bookmark.data.author, bookmark.data.source].filter(Boolean).join(" · ");
}

function hostname(bookmark: Bookmark): string {
  return new URL(bookmark.data.url).hostname.replace(/^www\./, "");
}

function faviconUrl(bookmark: Bookmark): string {
  return new URL("/favicon.ico", bookmark.data.url).toString();
}
---

<BaseLayout title={`Bookmarks / ${tag}`} wide>
  <section class="page-section" aria-labelledby="page-title">
    <h1 id="page-title" class="page-title">Bookmarks / {tag}</h1>

    {
      bookmarks.length === 0 ? (
        <p class="placeholder-list">Nothing here yet.</p>
      ) : (
        <div class="bookmark-list">
          {bookmarks.map((bookmark) => (
            <article class="bookmark-entry">
              <h2>
                <a href={bookmark.data.url}>{bookmark.data.title} ↗</a>
              </h2>
              <div class="bookmark-entry__meta">
                <span>
                  <img class="bookmark-favicon" src={faviconUrl(bookmark)} alt="" loading="lazy" data-optional-image />
                  {sourceLabel(bookmark) || hostname(bookmark)}
                </span>
                <time datetime={bookmark.data.savedAt.toISOString()}>{formatDate(bookmark.data.savedAt)}</time>
              </div>
              <p>{bookmark.body.trim()}</p>
              <div class="bookmark-entry__tags">
                {bookmark.data.tags.map((bookmarkTag) => <a href={`/bookmarks/tag/${bookmarkTag}`}>#{bookmarkTag}</a>)}
              </div>
            </article>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
