---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";

import { formatDate } from "../lib/date";

const now = await getEntry("pages", "now");

if (!now) {
  throw new Error("Missing now page content.");
}

const readingBooks = (await getCollection("bookshelf")).filter(
  (book) => book.data.status === "reading" && !book.data.draft,
);
const readingText = readingBooks.map((book) => `${book.data.title}, ${book.data.author}`).join("; ");
const workingOn = now.data.workingOn ?? "second-year coursework.";
const thinkingAbout = now.data.thinkingAbout ?? "what good engineering taste looks like, and how to develop it deliberately.";
const where = now.data.where ?? "[your city]";
---

<BaseLayout title="Now">
  <article class="page-section" aria-labelledby="page-title">
    <h1 id="page-title" class="page-title">Now</h1>
    {
      now.data.updatedAt && (
        <p class="page-intro">What I'm focused on, as of {formatDate(now.data.updatedAt)}.</p>
      )
    }
    <div class="prose">
      <p><strong>Working on</strong> &mdash; {workingOn}</p>
      <p><strong>Reading</strong> &mdash; {readingText}</p>
      <p><strong>Thinking about</strong> &mdash; {thinkingAbout}</p>
      <p><strong>Where</strong> &mdash; <em>{where}</em>.</p>
    </div>
  </article>
</BaseLayout>
