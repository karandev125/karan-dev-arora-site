---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { getCollection } from "astro:content";
import { formatDate } from "../../lib/date";

const thoughts = (await getCollection("thoughts"))
  .filter((thought) => !thought.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout title="Thoughts" wide>
  <section class="page-section" aria-labelledby="page-title">
    <h1 id="page-title" class="page-title">
      Thoughts{thoughts.length > 0 && <span class="mono"> ({thoughts.length})</span>}
    </h1>
    <p class="page-intro">Essays on engineering, philosophy, and whatever else holds my attention.</p>
    {
      thoughts.length > 0 ? (
        <div class="thought-list" aria-label="Thoughts">
          {thoughts.map((thought) => (
            <a class="thought-row" href={`/thoughts/${thought.slug}`}>
              <span class="thought-row__title" transition:name={`thought-title-${thought.slug}`}>
                {thought.data.title}
              </span>
              <time class="thought-row__date" datetime={thought.data.publishedAt.toISOString()}>
                {formatDate(thought.data.publishedAt)}
              </time>
            </a>
          ))}
        </div>
      ) : (
        <p class="placeholder-list">Nothing here yet.</p>
      )
    }
  </section>
</BaseLayout>
